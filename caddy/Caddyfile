{
    auto_https off
    servers {
        # Cloudflare IP ranges - INITIAL BOOTSTRAP, last verified: 2026-02-18
        # Source: https://www.cloudflare.com/ips/
        # IMPORTANT: These hardcoded IPs must be kept current. Set up periodic
        # synchronization via cron job (fetch from cloudflare.com/ips-v4 + ips-v6
        # and reload Caddy), or use a custom Caddy build with the caddy-cloudflare-ip
        # plugin for automatic updates: https://github.com/WeidiDeng/caddy-cloudflare-ip
        # See Task 16 checklist for setup instructions.
        trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
        trusted_proxies_strict
        client_ip_headers Cf-Connecting-Ip
    }
}

:80 {
    request_body {
        max_size 10MB
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "0"
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # TODO: Rate limiting for /auth/* endpoints.
    # Caddy's rate_limit module is not included in the standard binary and requires a custom build.
    # As an interim measure, use Cloudflare rate limiting rules for authentication endpoints.
    # When a custom Caddy build is feasible, add rate_limit directives here for /auth/* routes.

    # OpenTelemetry: browser trace export -> OTel Collector
    # Note: browser telemetry is inherently untrusted. Rate limiting and payload
    # size restrictions mitigate abuse but cannot prevent crafted fake traces.
    @otel_allowed {
        method POST OPTIONS
        path /otel/*
    }
    handle @otel_allowed {
        request_body {
            max_size 256KB
        }
        uri strip_prefix /otel
        reverse_proxy otel-collector:4318
    }
    # Reject other methods (GET, PUT, etc.) to /otel
    handle /otel/* {
        respond 405
    }

    # SignalR WebSocket hubs (more specific paths, matched before generic service routes)
    # Using `handle` + `uri strip_prefix` instead of `handle_path` to strip only the
    # service prefix while preserving `/hubs/...` in the forwarded path.
    #
    # Currently active SignalR hubs: events, messages, notifications
    # Pre-provisioned for future use: profiles, social, payments
    handle /events/hubs/* {
        uri strip_prefix /events
        reverse_proxy events-service:5010 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /messages/hubs/* {
        uri strip_prefix /messages
        reverse_proxy messages-service:5180 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /notifications/hubs/* {
        uri strip_prefix /notifications
        reverse_proxy notifications-service:5030 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /profiles/hubs/* {
        uri strip_prefix /profiles
        reverse_proxy profiles-service:5170 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /social/hubs/* {
        uri strip_prefix /social
        reverse_proxy social-service:5040 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /payments/hubs/* {
        uri strip_prefix /payments
        reverse_proxy payments-service:5050 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /coaching/hubs/evaluation* {
        uri strip_prefix /coaching
        reverse_proxy coaching-service:5060 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }

    # REST API routes
    handle_path /auth/* {
        reverse_proxy auth-service:5005
    }
    handle_path /events/* {
        reverse_proxy events-service:5010
    }
    handle_path /clubs/* {
        reverse_proxy clubs-service:5020
    }
    handle_path /profiles/* {
        reverse_proxy profiles-service:5170
    }
    handle_path /messages/* {
        reverse_proxy messages-service:5180
    }
    handle_path /notifications/* {
        reverse_proxy notifications-service:5030
    }
    handle_path /social/* {
        reverse_proxy social-service:5040
    }
    handle_path /coaching/* {
        reverse_proxy coaching-service:5060
    }
    handle_path /payments/* {
        reverse_proxy payments-service:5050
    }

    # Default: route to frontend container
    handle {
        reverse_proxy frontend:3000
    }

    encode zstd gzip {
        minimum_length 256
    }
}
