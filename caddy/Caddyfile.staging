# Staging Caddyfile — Cloudflare proxy (orange cloud) handles TLS, Caddy serves HTTP only
{
    auto_https off
    servers {
        client_ip_headers X-Forwarded-For
        timeouts {
            read_header 10s
        }
    }
}

(common_headers) {
    header {
        X-Content-Type-Options nosniff
        X-Robots-Tag "noindex, nofollow"
        X-Frame-Options DENY
        X-XSS-Protection "0"
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }
}

# API domain — routes to backend microservices
staging-api.volleyspike.app:80 {
    import common_headers

    request_body {
        max_size 10MB
    }

    # OpenTelemetry: browser trace export -> OTel Collector
    @otel_allowed {
        method POST OPTIONS
        path /otel/*
    }
    handle @otel_allowed {
        request_body {
            max_size 256KB
        }
        uri strip_prefix /otel
        reverse_proxy otel-collector:4318
    }
    handle /otel/* {
        respond 405
    }

    # SignalR WebSocket hubs
    handle /events/hubs/* {
        uri strip_prefix /events
        reverse_proxy events-service:5010 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /messages/hubs/* {
        uri strip_prefix /messages
        reverse_proxy messages-service:5180 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /notifications/hubs/* {
        uri strip_prefix /notifications
        reverse_proxy notifications-service:5030 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /profiles/hubs/* {
        uri strip_prefix /profiles
        reverse_proxy profiles-service:5170 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /social/hubs/* {
        uri strip_prefix /social
        reverse_proxy social-service:5040 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /payments/hubs/* {
        uri strip_prefix /payments
        reverse_proxy payments-service:5050 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }
    handle /coaching/hubs/evaluation* {
        uri strip_prefix /coaching
        reverse_proxy coaching-service:5060 {
            flush_interval -1
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
        }
    }

    # REST API routes
    handle_path /auth/* {
        reverse_proxy auth-service:5005
    }
    handle_path /events/* {
        reverse_proxy events-service:5010
    }
    handle_path /clubs/* {
        reverse_proxy clubs-service:5020
    }
    handle_path /profiles/* {
        reverse_proxy profiles-service:5170
    }
    handle_path /messages/* {
        reverse_proxy messages-service:5180
    }
    handle_path /notifications/* {
        reverse_proxy notifications-service:5030
    }
    handle_path /social/* {
        reverse_proxy social-service:5040
    }
    handle_path /coaching/* {
        reverse_proxy coaching-service:5060
    }
    handle_path /payments/* {
        reverse_proxy payments-service:5050
    }

    # Fallback: 404 for unknown API routes
    handle {
        respond "Not Found" 404
    }

    encode zstd gzip {
        minimum_length 256
    }
}

# Frontend domain — routes to Next.js
staging.volleyspike.app:80 staging-app.volleyspike.app:80 {
    import common_headers

    request_body {
        max_size 10MB
    }

    # OpenTelemetry: browser trace export -> OTel Collector
    @otel_allowed {
        method POST OPTIONS
        path /otel/*
    }
    handle @otel_allowed {
        request_body {
            max_size 256KB
        }
        uri strip_prefix /otel
        reverse_proxy otel-collector:4318
    }
    handle /otel/* {
        respond 405
    }

    # Everything else -> Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }

    encode zstd gzip {
        minimum_length 256
    }
}
