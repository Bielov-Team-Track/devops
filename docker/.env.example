# AWS Credentials for Development
# Copy this file to .env and fill in your actual AWS credentials
# The .env file is gitignored and will not be committed

# AWS Credentials (shared across all services in development)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# AWS Region
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your AWS credentials from AWS Console
# 3. The credentials will be used by all microservices (auth, profiles, messages, events)
# 4. Required AWS services: S3 (file storage), SES (email service)
