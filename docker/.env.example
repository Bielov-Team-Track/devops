# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
# This file documents variables needed for docker-compose.yml interpolation.
# For development: copy to .env and fill in values.
# For staging/production: setup-server.sh generates all .env files automatically.
# =============================================================================

# --- AWS Credentials (required for S3 uploads and SES email) ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=eu-west-2
AWS_DEFAULT_REGION=eu-west-2

# --- Infrastructure Passwords (auto-generated by setup-server.sh) ---
# POSTGRES_PASSWORD=<generated>
# REDIS_PASSWORD=<generated>
# RABBITMQ_DEFAULT_USER=volleyer
# RABBITMQ_DEFAULT_PASS=<generated>

# --- Per-Service Config (injected via .env.{service} files) ---
# See setup-server.sh for the full list of per-service variables:
#   ConnectionStrings__DefaultConnection, Jwt__Secret, Cors__AllowedOrigins__0,
#   S3__Bucket, S3__PublicBaseUrl, Stripe__ApiKey, etc.
